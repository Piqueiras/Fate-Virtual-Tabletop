<!-- app/views/rooms/_item_modal.html.erb -->
<div data-controller="item-modal" data-item-modal-room-id-value="<%= @room.id %>">
  
  <!-- Botón de Crear Objeto -->
  <button type="button" data-action="click->item-modal#open" class="flex h-10 px-4 items-center justify-center rounded-full bg-amber-50 border border-amber-200 text-sm font-bold text-amber-700 hover:bg-amber-100 shadow-sm transition-all focus:outline-none">
    💎 Objeto
  </button>

  <!-- MODAL DE CREACIÓN DE OBJETOS -->
  <div data-item-modal-target="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4 cursor-default">
    <div class="bg-white rounded-3xl shadow-2xl w-[360px] flex flex-col overflow-hidden border border-slate-200">
      
      <!-- Cabecera -->
      <div class="flex items-center justify-between p-4 border-b border-slate-100 bg-slate-50">
        <h3 class="font-bold text-slate-800">Crear Objeto</h3>
        <button type="button" data-action="click->item-modal#close" class="text-slate-400 hover:text-slate-700 font-bold text-lg leading-none">&times;</button>
      </div>

      <!-- Cuerpo -->
      <div class="p-4 space-y-4">
        <input type="text" data-item-modal-target="nameInput" placeholder="Nombre (ej. Poción, Llave...)" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-900 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 shadow-sm outline-none">
        <textarea data-item-modal-target="descInput" placeholder="Descripción del objeto..." rows="2" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-900 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 shadow-sm outline-none resize-none"></textarea>
        <label class="block w-full border-2 border-dashed border-indigo-200 bg-indigo-50/50 rounded-xl p-3 text-center cursor-pointer hover:bg-indigo-50 transition-colors">
          <span class="text-sm font-bold text-indigo-600">📁 Subir Imagen</span>
          <input type="file" accept="image/*" class="hidden" data-action="change->item-modal#handleFileUpload">
        </label>

        <div class="flex items-center gap-2">
          <div class="h-px bg-slate-200 flex-1"></div>
          <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">o Dibuja Abajo</span>
          <div class="h-px bg-slate-200 flex-1"></div>
        </div>

        <div class="relative w-full aspect-square bg-slate-50 border-2 border-slate-200 rounded-xl overflow-hidden touch-none cursor-crosshair">
          <canvas data-item-modal-target="canvas" 
                  data-action="pointerdown->item-modal#startDrawing pointermove->item-modal#draw pointerup->item-modal#stopDrawing pointerout->item-modal#stopDrawing" 
                  class="w-full h-full relative z-10"></canvas>
          
          <img data-item-modal-target="preview" class="hidden absolute inset-0 z-20 w-full h-full object-cover pointer-events-none bg-white">
        </div>
      </div>

      <!-- Footer -->
      <div class="p-4 border-t border-slate-100 flex gap-2">
        <button type="button" data-action="click->item-modal#close" class="flex-1 py-2 rounded-xl text-sm font-bold text-slate-600 hover:bg-slate-100 transition-colors">Cancelar</button>
        <button type="button" data-action="click->item-modal#submit" data-item-modal-target="submitBtn" class="flex-1 py-2 rounded-xl bg-indigo-600 text-sm font-bold text-white hover:bg-indigo-700 shadow-md transition-colors active:scale-95">Crear Objeto</button>
      </div>

    </div>
  </div>
</div>