<div class="h-screen overflow-hidden grid grid-cols-1 lg:grid-cols-[20%_1fr_20%] bg-slate-100" data-controller="room-board" data-room-board-room-id-value="<%= @room.id %>">
  <aside class="border-r border-slate-200 bg-white p-6 overflow-y-auto">
    <div class="mb-6">
      <h1 class="text-xl font-black text-slate-900">Roster</h1>
      <p class="text-sm text-slate-500">Personajes propios</p>
    </div>

    <div class="space-y-4">
      <% @available_characters.each do |character| %>
        <div draggable="true" data-room-board-character-id-value="<%= character.id %>" data-action="dragstart->room-board#startRosterDrag dragend->room-board#endRosterDrag" class="rounded-3xl border border-slate-200 bg-slate-50 p-4 shadow-sm hover:border-indigo-300 hover:bg-indigo-100 transition cursor-grab">
          <div class="flex items-center justify-between gap-3">
            <span class="font-semibold text-slate-900"><%= character.name %></span>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs uppercase tracking-widest text-slate-500"><%= character.fate_points || 0 %></span>
          </div>
          <div class="mt-3 flex items-center gap-2">
            <%= link_to "Inspeccionar", character_path(character), class: "rounded-full bg-white px-4 py-2 text-xs font-semibold text-slate-700 border border-slate-200 hover:bg-slate-100 transition", data: { turbo_action: "advance" } %>
            <%= link_to "Editar", edit_character_path(character), class: "rounded-full bg-indigo-600 px-4 py-2 text-xs font-semibold text-white hover:bg-indigo-700 transition" %>
          </div>
        </div>
      <% end %>
    </div>
  </aside>

  <main class="relative p-6 overflow-hidden flex flex-col min-h-[calc(100vh-5rem)]">
    <div class="rounded-3xl bg-white p-4 shadow-sm border border-slate-200 mb-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h2 class="text-2xl font-black text-slate-900"><%= @room.name %></h2>
          <p class="text-sm text-slate-500">DM: <%= @room.dm.username %></p>
        </div>
        <span class="rounded-full bg-slate-100 px-3 py-2 text-xs uppercase tracking-widest text-slate-600"><%= @room.public? ? "Sala Pública" : "Sala Privada" %></span>
      </div>
    </div>

    <div class="space-y-6">
      <div class="relative min-h-[420px] overflow-hidden rounded-3xl border border-slate-200 bg-white" data-action="dragover->room-board#allowDrop dragenter->room-board#allowDrop dragleave->room-board#leaveDrop drop->room-board#drop" data-room-board-target="board">
        <div class="relative h-full touch-action-none min-h-[420px]">
          <% if @room.background_image.attached? %>
            <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('<%= url_for(@room.background_image) %>');"></div>
          <% else %>
            <div class="absolute inset-0 bg-gradient-to-br from-slate-200 via-slate-100 to-white"></div>
          <% end %>
          <div class="absolute inset-0 bg-slate-900/10 pointer-events-none"></div>

          <div class="relative h-full">
            <% @room_characters.where(is_active: true).each do |room_character| %>
              <div data-room-board-target="token" data-room-board-room-character-id-value="<%= room_character.id %>" data-action="pointerdown->room-board#startDrag" class="absolute rounded-xl border border-indigo-500 shadow-lg cursor-grab touch-none overflow-hidden bg-slate-100" style="left: <%= room_character.pos_x %>px; top: <%= room_character.pos_y %>px; width: 120px; height: 120px;">
                <% if room_character.character.avatar.attached? %>
                  <%= image_tag room_character.character.avatar, class: "h-full w-full object-cover", alt: "" %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="rounded-3xl border border-dashed border-slate-300 bg-slate-50 p-5 min-h-[180px]" data-room-board-target="activeList" data-action="dragover->room-board#allowDrop dragenter->room-board#allowDrop dragleave->room-board#leaveDrop drop->room-board#dropActive">
        <div class="flex items-center justify-between gap-4 mb-4">
          <div>
            <h3 class="text-sm uppercase tracking-widest text-slate-500 font-bold">Personajes Activos</h3>
            <p class="text-xs text-slate-500">Suelta aquí para activar un personaje y colocarlo en el centro del tablero.</p>
          </div>
          <span class="rounded-full bg-white px-3 py-1 text-xs uppercase tracking-widest text-slate-500 border border-slate-200">Drop zone</span>
        </div>
        <div class="space-y-3">
          <% @room_characters.where(is_active: true).each do |room_character| %>
            <div data-room-board-room-character-id-value="<%= room_character.id %>" data-character-id="<%= room_character.character.id %>" class="relative rounded-3xl border border-slate-200 bg-white p-4">
              <button type="button" data-action="click->room-board#removeRoomCharacter" class="absolute right-3 top-3 inline-flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 text-slate-700 hover:bg-slate-200">
                ×
              </button>
                <div class="space-y-3">
                  <p class="character-name font-semibold text-slate-900"><%= room_character.character.name %></p>
                  <div class="flex flex-wrap items-center gap-3 text-xs text-slate-500">
                    <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-2 py-1">
                      <span class="uppercase tracking-widest">Destino</span>
                      <button type="button" data-action="click->room-board#changeFatePoints" data-fate-delta="-1" class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-white text-slate-700 shadow-sm hover:bg-slate-100">-</button>
                      <span data-room-board-target="fatePoints" class="min-w-[2rem] text-center font-semibold text-slate-900"><%= room_character.character.fate_points || 0 %></span>
                      <button type="button" data-action="click->room-board#changeFatePoints" data-fate-delta="1" class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-white text-slate-700 shadow-sm hover:bg-slate-100">+</button>
                    </div>
                    <div class="inline-flex items-center gap-2">
                      <span class="uppercase tracking-widest">Físico</span>
                      <% room_character.character.physical_stress_capacity.times do |index| %>
                        <% filled = room_character.character.physical_stress_slot?(index) %>
                        <button type="button" data-action="click->room-board#toggleStressSlot" data-stress-type="physical" data-stress-index="<%= index %>" data-filled="<%= filled %>" aria-pressed="<%= filled %>" class="h-7 w-7 rounded-full border-2 transition-colors duration-150 focus:outline-none focus:ring-0 cursor-pointer <%= filled ? 'border-red-600 bg-red-600' : 'border-red-600/70 bg-white' %>"></button>
                      <% end %>
                    </div>
                    <div class="inline-flex items-center gap-2">
                      <span class="uppercase tracking-widest">Mental</span>
                      <% room_character.character.mental_stress_capacity.times do |index| %>
                        <% filled = room_character.character.mental_stress_slot?(index) %>
                        <button type="button" data-action="click->room-board#toggleStressSlot" data-stress-type="mental" data-stress-index="<%= index %>" data-filled="<%= filled %>" aria-pressed="<%= filled %>" class="h-7 w-7 rounded-full border-2 transition-colors duration-150 focus:outline-none focus:ring-0 cursor-pointer <%= filled ? 'border-blue-600 bg-blue-600' : 'border-blue-600/70 bg-white' %>"></button>
                      <% end %>
                    </div>
                  </div>
                </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </main>

  <aside class="border-l border-slate-200 bg-white p-6 overflow-y-auto">
    <div class="mb-6">
      <h2 class="text-xl font-black text-slate-900">Game Log</h2>
      <p class="text-sm text-slate-500">Actualizaciones de la sala en tiempo real.</p>
    </div>

    <div class="space-y-3 max-h-[calc(100vh-160px)] overflow-y-auto" data-room-board-target="gameLogList">
      <% @room.game_logs.order(created_at: :desc).each do |log| %>
        <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700">
          <p><%= log.message %></p>
          <p class="mt-2 text-xs text-slate-500"><%= l(log.created_at, format: :short) %></p>
        </div>
      <% end %>
    </div>
  </aside>
</div>
