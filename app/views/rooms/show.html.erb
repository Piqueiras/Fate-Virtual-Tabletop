<div class="min-h-screen grid grid-cols-1 lg:grid-cols-[20%_1fr_20%] bg-slate-100" data-controller="room-board" data-room-board-room-id-value="<%= @room.id %>">
  <script type="application/json" data-room-board-target="canvasDataStore"><%= @room.canvas_data || '' %></script>
  <aside class="border-r border-slate-200 bg-white p-6 overflow-y-auto">
    <div class="mb-6">
      <h1 class="text-xl font-black text-slate-900">Personajes</h1>
    </div>

    <div class="space-y-4">
      <% @available_characters.each do |character| %>
        <div draggable="true" data-room-board-character-id-value="<%= character.id %>" data-action="dragstart->room-board#startRosterDrag dragend->room-board#endRosterDrag" class="rounded-3xl border border-slate-200 bg-slate-50 p-4 shadow-sm hover:border-indigo-300 hover:bg-indigo-100 transition cursor-grab">
          <div class="flex items-center justify-between gap-3">
            <span class="font-semibold text-slate-900"><%= character.name %></span>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs uppercase tracking-widest text-slate-500"><%= character.fate_points || 0 %></span>
          </div>
          <div class="mt-3 flex items-center gap-2">
            <%= link_to "Inspeccionar", character_path(character), class: "rounded-full bg-white px-4 py-2 text-xs font-semibold text-slate-700 border border-slate-200 hover:bg-slate-100 transition", data: { turbo_action: "advance" } %>
            <%= link_to "Editar", edit_character_path(character), class: "rounded-full bg-indigo-600 px-4 py-2 text-xs font-semibold text-white hover:bg-indigo-700 transition" %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-8 pt-6 border-t border-slate-200 flex-1 min-h-0 flex flex-col">
        <div class="mb-4 shrink-0">
          <h2 class="text-sm font-black text-slate-900 uppercase tracking-widest">Inventario</h2>
          <p class="text-xs text-slate-500 mt-1">Arrastra objetos al tablero o viceversa</p>
        </div>

        <div class="space-y-4 overflow-y-auto flex-1 pb-4 pr-2">
          <% current_user.characters.each do |character| %>
            
            <!-- La tarjeta del inventario: Le ponemos el data-character-id para que actúe como Imán -->
            <div class="bg-slate-50 p-3 rounded-2xl border border-slate-200" data-character-id="<%= character.id %>">
              <h3 class="text-xs font-bold text-slate-700 mb-3 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-indigo-500"></div>
                <%= character.name %>
              </h3>
              
              <!-- Lista de objetos -->
              <div class="space-y-2 min-h-[40px]">
                <% items = @room.items.where(character_id: character.id, on_board: false) %>
                
                <% if items.empty? %>
                  <p class="text-[10px] text-slate-400 font-medium text-center py-2 italic border border-dashed border-slate-300 rounded-xl pointer-events-none">Vacío</p>
                <% else %>
                  <% items.each do |item| %>
                    
                    <!-- OBJETO DRAGGABLE -->
                    <div class="flex items-center gap-3 p-2 bg-white rounded-xl shadow-sm border border-slate-200 cursor-grab active:cursor-grabbing hover:border-indigo-300 transition-colors"
                         draggable="true"
                         data-action="dragstart->room-board#startItemDrag dragend->room-board#endItemDrag"
                         data-item-id="<%= item.id %>">
                      <div class="w-8 h-8 shrink-0 bg-amber-50 rounded-lg border border-amber-200 overflow-hidden flex items-center justify-center">
                        <% if item.image.attached? %>
                          <%= image_tag item.image, class: "w-full h-full object-cover pointer-events-none" %>
                        <% else %>
                          <span class="text-sm pointer-events-none">📦</span>
                        <% end %>
                      </div>
                      <div class="min-w-0">
                        <p class="text-xs font-bold text-slate-700 truncate"><%= item.name %></p>
                      </div>
                    </div>
                    
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
  </aside>

  <main class="relative p-6 flex flex-col min-h-[calc(100vh-5rem)]">
    <div class="rounded-3xl bg-white p-4 shadow-sm border border-slate-200 mb-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h2 class="text-2xl font-black text-slate-900"><%= @room.name %></h2>
          <p class="text-sm text-slate-500">DM: <%= @room.dm.username %></p>
        </div>
        <span class="rounded-full bg-slate-100 px-3 py-2 text-xs uppercase tracking-widest text-slate-600"><%= @room.public? ? "Sala Pública" : "Sala Privada" %></span>
      </div>
    </div>

    <div class="space-y-6">
        <div class="relative w-full overflow-hidden rounded-3xl border border-slate-200 bg-white" data-action="dragover->room-board#allowDrop dragenter->room-board#allowDrop dragleave->room-board#leaveDrop drop->room-board#drop" data-room-board-target="board">
        
        <img data-room-board-target="spacer" src="<%= @room.background_image.attached? ? url_for(@room.background_image) : '' %>" class="w-full h-auto opacity-0 pointer-events-none select-none <%= @room.background_image.attached? ? 'block' : 'hidden' %>" />

        <div class="absolute left-4 top-4 z-30 flex items-center gap-2">
          <div class="flex items-center bg-white/90 p-1 rounded-full border border-slate-200 shadow-sm">
            <button type="button" data-action="click->room-board#zoomOut" class="flex h-8 w-8 items-center justify-center rounded-full text-slate-600 hover:bg-slate-200 transition focus:outline-none" title="Reducir tokens">
              <span class="text-xl font-bold leading-none">−</span>
            </button>
            <div class="w-px h-4 bg-slate-300 mx-1"></div>
            <button type="button" data-action="click->room-board#zoomIn" class="flex h-8 w-8 items-center justify-center rounded-full text-slate-600 hover:bg-slate-200 transition focus:outline-none" title="Aumentar tokens">
              <span class="text-xl font-bold leading-none">+</span>
            </button>
          </div>

          <button type="button" data-action="click->room-board#toggleDrawMode" data-room-board-target="drawBtn" class="flex h-10 px-4 items-center justify-center rounded-full bg-white/90 border border-slate-200 text-sm font-bold text-slate-700 hover:bg-slate-100 shadow-sm transition-all focus:outline-none" title="Activar/Desactivar pintura">
            🖌️ Dibujar
          </button>

          <!-- Drawing Toolbar (hidden unless draw mode is active) -->
          <div data-room-board-target="drawToolbar" class="hidden flex items-center gap-1 bg-white/90 p-1 rounded-full border border-slate-200 shadow-sm">
            <!-- Color palette -->
            <button type="button" data-action="click->room-board#selectColor" data-color="#000000" class="h-7 w-7 rounded-full border-2 border-white shadow-sm ring-1 ring-slate-300" style="background: #000000" title="Negro"></button>
            <button type="button" data-action="click->room-board#selectColor" data-color="#ef4444" class="h-7 w-7 rounded-full border-2 border-white shadow-sm ring-1 ring-slate-300" style="background: #ef4444" title="Rojo"></button>
            <button type="button" data-action="click->room-board#selectColor" data-color="#3b82f6" class="h-7 w-7 rounded-full border-2 border-white shadow-sm ring-1 ring-slate-300" style="background: #3b82f6" title="Azul"></button>
            <button type="button" data-action="click->room-board#selectColor" data-color="#22c55e" class="h-7 w-7 rounded-full border-2 border-white shadow-sm ring-1 ring-slate-300" style="background: #22c55e" title="Verde"></button>
            <button type="button" data-action="click->room-board#selectColor" data-color="#f97316" class="h-7 w-7 rounded-full border-2 border-white shadow-sm ring-1 ring-slate-300" style="background: #f97316" title="Naranja"></button>
            <div class="w-px h-5 bg-slate-300 mx-1"></div>
            <!-- Eraser -->
            <button type="button" data-action="click->room-board#toggleEraser" data-room-board-target="eraserBtn" class="flex h-7 w-7 items-center justify-center rounded-full text-sm hover:bg-slate-200 transition" title="Goma de borrar">
              🧹
            </button>
            <div class="w-px h-5 bg-slate-300 mx-1"></div>
            <!-- Clear Canvas -->
            <button type="button" data-action="click->room-board#clearCanvas" data-room-board-target="clearCanvasBtn" class="flex h-7 w-7 items-center justify-center rounded-full text-sm hover:bg-red-100 transition" title="Borrar todo el dibujo">
              🗑️
            </button>
          </div>

          <%= render "item_modal" %>
        </div>

        <div class="absolute right-4 top-4 z-30">
          <label class="group inline-flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border border-slate-200 bg-white/90 text-slate-700 shadow-sm transition hover:bg-slate-100" title="Subir fondo del tablero">
            <span class="text-lg">🖼</span>
            <input type="file" accept="image/*" class="sr-only" data-action="change->room-board#submitBackgroundImage" />
          </label>
        </div>

        <div data-room-board-target="background" class="absolute inset-0 z-0 <%= @room.background_image.attached? ? 'bg-cover bg-center' : 'bg-gradient-to-br from-slate-200 via-slate-100 to-white' %>" style="<%= @room.background_image.attached? ? "background-image: url('#{url_for(@room.background_image)}');" : '' %>"></div>
        <div class="absolute inset-0 z-10 bg-slate-900/10 pointer-events-none"></div>

        <canvas data-room-board-target="canvas" 
                data-action="pointerdown->room-board#startDrawing pointermove->room-board#draw pointerup->room-board#stopDrawing pointerout->room-board#stopDrawing" 
                class="absolute inset-0 z-[15] touch-none pointer-events-none w-full h-full">
        </canvas>

        <div class="absolute inset-0 z-20 touch-none" data-room-board-target="tokenLayer" id="board_tokens">
          <% @room_characters.where(is_active: true).each do |room_character| %>
            <%= render "board_token", room_character: room_character %>
          <% end %>

          <% @room.items.where(on_board: true).each do |item| %>
            <%= render "board_item", item: item %>
          <% end %>
        </div>
      </div>

      <div class="rounded-3xl border border-dashed border-slate-300 bg-slate-50 p-5 min-h-[180px]" data-room-board-target="activeList" data-action="dragover->room-board#allowDrop dragenter->room-board#allowDrop dragleave->room-board#leaveDrop drop->room-board#dropActive">
        <div class="flex items-center justify-between gap-4 mb-4">
          <div>
            <h3 class="text-sm uppercase tracking-widest text-slate-500 font-bold">Personajes Activos</h3>
            <p class="text-xs text-slate-500">Suelta aquí para activar un personaje y colocarlo en el centro del tablero.</p>
          </div>
          <span class="rounded-full bg-white px-3 py-1 text-xs uppercase tracking-widest text-slate-500 border border-slate-200">Drop zone</span>
        </div>
        
        <div class="space-y-3">
          <% @room_characters.where(is_active: true).each do |room_character| %>
            <% aspects = Array(room_character.character.aspects || []) %>
            <% skills_hash = room_character.character.skills || {} %>

            <details data-room-board-room-character-id-value="<%= room_character.id %>" data-character-id="<%= room_character.character.id %>" class="relative rounded-3xl border border-slate-200 bg-white">
              
              <summary class="group grid cursor-pointer items-center grid-cols-[30%_minmax(0,1fr)_auto] gap-3 p-4 list-none">
                <p class="character-name min-w-0 overflow-hidden text-ellipsis whitespace-nowrap font-semibold text-slate-900"><%= room_character.character.name %></p>
                
                <div class="flex items-center gap-5 text-xs text-slate-500 min-w-0">
                  <span class="inline-flex h-8 min-w-[2rem] items-center justify-center rounded-full border border-slate-200 bg-slate-50 px-2 text-sm font-semibold text-slate-900"><%= room_character.character.fate_points || 0 %></span>
                  
                  <div class="flex items-center gap-1 w-36">
                    <% room_character.character.physical_stress_capacity.times do |index| %>
                      <% filled = room_character.character.physical_stress_slot?(index) %>
                      <span class="h-7 w-7 shrink-0 rounded-full border-2 <%= filled ? 'border-red-600 bg-red-600' : 'border-red-600/70 bg-white' %>"></span>
                    <% end %>
                  </div>
                  
                  <div class="flex items-center gap-1">
                    <% room_character.character.mental_stress_capacity.times do |index| %>
                      <% filled = room_character.character.mental_stress_slot?(index) %>
                      <span class="h-7 w-7 shrink-0 rounded-full border-2 <%= filled ? 'border-blue-600 bg-blue-600' : 'border-blue-600/70 bg-white' %>"></span>
                    <% end %>
                  </div>
                </div>
                
                <span class="text-xs uppercase tracking-widest text-slate-400 group-open:text-slate-500">Más</span>
              </summary>

              <button type="button" data-action="click->room-board#removeRoomCharacter" class="absolute right-3 top-3 inline-flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 text-slate-700 hover:bg-slate-200">
                ×
              </button>

              <div class="border-t border-slate-200 px-4 pb-4 pt-4">
                <div class="grid gap-4 lg:grid-cols-2">
                  
                  <div class="space-y-3">
                    <h4 class="text-xs uppercase tracking-widest text-slate-500">Aspectos</h4>
                    <% if aspects.any? %>
                      <div class="grid gap-2">
                        <% aspects.each do |aspect| %>
                          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
                            <p class="text-[10px] uppercase tracking-widest text-slate-500"><%= aspect["title"].presence || "Aspecto" %></p>
                            <p class="font-semibold text-slate-900"><%= aspect["name"].presence || "Sin nombre" %></p>
                            <% if aspect["description"].present? %>
                              <p class="mt-2 text-sm text-slate-600"><%= aspect["description"] %></p>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    <% else %>
                      <p class="text-sm text-slate-500">Sin aspectos definidos.</p>
                    <% end %>
                  </div>

                  <div class="space-y-3">
                    <h4 class="text-xs uppercase tracking-widest text-slate-500">Pirámide de skills</h4>
                    <% Character::SKILLS_LEVELS.reverse.each do |level| %>
                      <% skills = Array(skills_hash[level[:key]]).reject(&:blank?) %>
                      <% next if skills.empty? %>
                      <div class="flex flex-wrap items-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-700">
                        <span class="font-semibold text-slate-900"><%= level[:display] %></span>
                        <span class="text-slate-500">•</span>
                        <span class="flex flex-wrap gap-2">
                          <% skills.each do |skill| %>
                            <span class="rounded-full bg-white px-2 py-1 text-[11px] text-slate-700"><%= skill %></span>
                          <% end %>
                        </span>
                      </div>
                    <% end %>
                    <% if Character::SKILLS_LEVELS.all? { |level| Array(skills_hash[level[:key]]).reject(&:blank?).empty? } %>
                      <p class="text-sm text-slate-500">Sin skills asignadas.</p>
                    <% end %>
                  </div>
                </div>

                <% consecuencias_reales = Array(room_character.character.consequences).reject(&:blank?) %>
                <% if consecuencias_reales.any? %>
                  <div class="mt-4 space-y-3">
                    <h4 class="text-xs uppercase tracking-widest text-slate-500">Consecuencias</h4>
                    <div class="grid gap-2 sm:grid-cols-2">
                      <% consecuencias_reales.each do |cons| %>
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">
                          <%= cons %>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>

                <div class="mt-4 grid gap-3 sm:grid-cols-2">
                  <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
                    <p class="text-xs uppercase tracking-widest text-slate-500">Destino</p>
                    <div class="mt-2 flex items-center gap-2">
                      <button type="button" data-action="click->room-board#changeFatePoints" data-fate-delta="-1" class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white text-slate-700 shadow-sm hover:bg-slate-100">-</button>
                      <span data-room-board-target="fatePoints" class="min-w-[2rem] text-center font-semibold text-slate-900"><%= room_character.character.fate_points || 0 %></span>
                      <button type="button" data-action="click->room-board#changeFatePoints" data-fate-delta="1" class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white text-slate-700 shadow-sm hover:bg-slate-100">+</button>
                    </div>
                  </div>

                  <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
                    <p class="text-xs uppercase tracking-widest text-slate-500">Estrés</p>
                    <div class="mt-2 space-y-2">
                      <div>
                        <p class="text-[10px] uppercase tracking-widest text-slate-500">Físico</p>
                        <div class="mt-2 flex flex-wrap gap-2">
                          <% room_character.character.physical_stress_capacity.times do |index| %>
                            <% filled = room_character.character.physical_stress_slot?(index) %>
                            <button type="button" data-action="click->room-board#toggleStressSlot" data-stress-type="physical" data-stress-index="<%= index %>" data-filled="<%= filled %>" aria-pressed="<%= filled %>" class="h-8 w-8 rounded-full border-2 transition-colors duration-150 focus:outline-none focus:ring-0 cursor-pointer <%= filled ? 'border-red-600 bg-red-600' : 'border-red-600/70 bg-white' %>"></button>
                          <% end %>
                        </div>
                      </div>
                      <div>
                        <p class="text-[10px] uppercase tracking-widest text-slate-500">Mental</p>
                        <div class="mt-2 flex flex-wrap gap-2">
                          <% room_character.character.mental_stress_capacity.times do |index| %>
                            <% filled = room_character.character.mental_stress_slot?(index) %>
                            <button type="button" data-action="click->room-board#toggleStressSlot" data-stress-type="mental" data-stress-index="<%= index %>" data-filled="<%= filled %>" aria-pressed="<%= filled %>" class="h-8 w-8 rounded-full border-2 transition-colors duration-150 focus:outline-none focus:ring-0 cursor-pointer <%= filled ? 'border-blue-600 bg-blue-600' : 'border-blue-600/70 bg-white' %>"></button>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

              </div>
            </details>
          <% end %>
        </div>
      </div>
    </div>
  </main>

  <aside class="border-l border-slate-200 bg-white p-6 flex flex-col h-[calc(100vh-6rem)] sticky top-6">
    <div class="mb-6 shrink-0">
      <h2 class="text-xl font-black text-slate-900">Registro</h2>
    </div>

    <div class="mb-6 shrink-0 flex gap-2">
      <button type="button" 
          data-action="click->room-board#rollDice" 
          data-user-name="<%= current_user.username %>"
          class="flex-1 flex items-center justify-center gap-2 rounded-2xl bg-indigo-600 px-4 py-3 text-sm font-bold text-white hover:bg-indigo-700 shadow-md transition-all active:scale-95">
          <span class="text-lg">🎲</span> Lanzar
      </button>

      <% if @room.dm == current_user %>
        <button type="button" 
            data-action="click->room-board#clearLog" 
            class="flex items-center justify-center rounded-2xl bg-red-50 border border-red-200 px-4 py-3 text-sm font-bold text-red-600 hover:bg-red-100 shadow-sm transition-all active:scale-95"
            title="Limpiar registro">
            <span class="text-lg">🗑️</span>
        </button>
      <% end %>
    </div>

    <%= turbo_stream_from @room %>

    <div id="room_<%= @room.id %>_game_logs" class="space-y-3 overflow-y-auto flex-1 min-h-0 pb-4 pr-2" data-room-board-target="gameLogList">
      <% @room.game_logs.order(created_at: :desc).each do |log| %>
        <%= render partial: "game_logs/game_log", locals: { log: log } %>
      <% end %>
    </div>
  </aside>
</div>
