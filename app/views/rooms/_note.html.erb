<%# locals: note, is_owner: false, is_dm: false, can_edit: false, locked_by_me: false %>
<% is_locked = note.locked? %>

<div id="note_<%= note.id %>" class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm hover:shadow-md transition-shadow"
     data-note-id="<%= note.id %>"
     data-note-public="<%= note.public %>"
     data-note-locked="<%= is_locked %>"
     data-note-locked-by="<%= note.locked_by_user&.username %>"
     data-note-content="<%= CGI.escapeHTML(note.content.to_s) %>">
  
  <%# ── Cabecera ─────────────────────── %>
  <div class="flex items-start justify-between gap-2 mb-2">
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2">
        <h4 class="text-sm font-bold text-slate-900 truncate"><%= note.title %></h4>
        <% if note.public? %>
          <span class="shrink-0 rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-emerald-700">🌍 Pública</span>
        <% else %>
          <span class="shrink-0 rounded-full bg-violet-100 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-violet-700">🔒 Privada</span>
        <% end %>
      </div>
      <p class="text-[10px] text-slate-400 mt-0.5">
        por <span class="font-semibold text-slate-500"><%= note.user.username %></span>
        <% if is_locked && !locked_by_me %>
          · 🔒 <span class="font-semibold text-amber-600"><%= note.locked_by_user.username %></span> está editando...
        <% end %>
      </p>
    </div>

    <%# ── Botones de acción ───────────── %>
    <div class="flex items-center gap-1 shrink-0">
      <% if can_edit && !is_locked || locked_by_me %>
        <button type="button" data-action="click->notes#editNote" data-note-id="<%= note.id %>"
                class="flex h-7 w-7 items-center justify-center rounded-full text-slate-400 hover:bg-slate-100 hover:text-slate-700 transition"
                title="Editar">✏️</button>
      <% end %>
      <% if is_owner || is_dm %>
        <button type="button" data-action="click->notes#deleteNote" data-note-id="<%= note.id %>"
                class="flex h-7 w-7 items-center justify-center rounded-full text-slate-400 hover:bg-red-50 hover:text-red-600 transition"
                title="Eliminar">🗑️</button>
      <% end %>
      <% if is_dm && is_locked %>
        <button type="button" data-action="click->notes#forceUnlock" data-note-id="<%= note.id %>"
                class="flex h-7 w-7 items-center justify-center rounded-full text-amber-500 hover:bg-amber-50 hover:text-amber-700 transition"
                title="Forzar desbloqueo">🔓</button>
      <% end %>
    </div>
  </div>

  <%# ── Contenido ────────────────────── %>
  <div class="prose prose-sm max-w-none text-slate-700 mt-3">
    <%= render_note_content(note) %>
  </div>

  <%# ── Dibujo (canvas) ──────────────── %>
  <% if note.drawing.attached? %>
    <div class="mt-3">
      <%= image_tag note.drawing, class: "rounded-xl max-w-full h-auto border-2 border-amber-200 cursor-pointer hover:border-amber-400 transition-colors", loading: "lazy", alt: "Dibujo", data: { drawing_signed_id: note.drawing.signed_id, action: "click->notes#editDrawing" }, title: "Clic para editar el dibujo" %>
    </div>
  <% end %>

  <%# ── Footer ───────────────────────── %>
  <div class="mt-3 pt-2 border-t border-slate-100 flex items-center justify-between text-[10px] text-slate-400">
    <span><%= time_ago_in_words(note.updated_at) %></span>
    <% if is_owner %>
      <button type="button" data-action="click->notes#togglePublic" data-note-id="<%= note.id %>"
              data-current-public="<%= note.public %>"
              class="font-semibold hover:text-indigo-600 transition">
        Hacer <%= note.public? ? "privada" : "pública" %>
      </button>
    <% end %>
  </div>
</div>