<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Fate Vtt" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Fate Vtt">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white text-slate-900">
    <header class="bg-white shadow-sm border-b border-slate-200">
      <div class="container mx-auto px-5 py-4 flex items-center justify-between">
        <div>
          <%= link_to "Fate Vtt", root_path, class: "text-xl font-black text-slate-900" %>
        </div>
        <div class="flex items-center gap-4">
          <% if user_signed_in? %>
            <%= link_to "Cerrar sesión", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm font-semibold text-slate-700 hover:text-slate-900" %>
          <% else %>
            <%= link_to "Iniciar sesión", new_user_session_path, class: "text-sm font-semibold text-slate-700 hover:text-slate-900" %>
            <%= link_to "Registrarse", new_user_registration_path, class: "text-sm font-semibold text-indigo-600 hover:text-indigo-800" %>
          <% end %>
        </div>
      </div>
    </header>

    <main class="container mx-auto mt-10 px-5">
      <%= yield %>
    </main>
  </body>
</html>
